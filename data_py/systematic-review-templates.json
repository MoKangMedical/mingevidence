          "title": "方法",
          "required": true,
          "items": ["检索策略", "纳入标准", "数据提取", "质量评价QUIPS", "统计分析"]
        }
      ],
      "quips_domains": ["研究参与", "预后因素测量", "结局测量", "混杂因素", "统计分析"]
    },
    {
      "id": "sr-etiology",
      "name": "病因学系统综述",
