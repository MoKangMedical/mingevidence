{
  "version": "1.0.0",
  "description": "系统综述模板库",
  "templates": [
    {
      "id": "sr-intervention",
      "name": "干预措施系统综述",
      "description": "评估干预措施效果的系统综述模板",
      "sections": [
        {
          "title": "背景与目的",
          "required": true,
          "items": ["研究背景", "研究问题", "PICO框架", "纳入排除标准"]
        },
        {
          "title": "方法",
          "required": true,
          "items": ["检索策略", "数据库选择", "文献筛选", "数据提取", "质量评价", "统计分析"]
        },
        {
          "title": "结果",
          "required": true,
          "items": ["文献筛选流程图", "纳入研究特征", "质量评价结果", "Meta分析结果", "异质性分析"]
        },
        {
          "title": "讨论",
          "required": true,
          "items": ["主要发现", "证据质量", "局限性", "临床意义", "未来研究方向"]
        }
      ],
      "pico_template": {
        "P": "目标人群",
        "I": "干预措施",
        "C": "对照措施",
        "O": "结局指标"
      }
    },
    {
      "id": "sr-diagnostic",
      "name": "诊断准确性系统综述",
      "description": "评估诊断试验准确性的系统综述模板",
      "sections": [
        {
          "title": "背景与目的",
          "required": true,
          "items": ["目标疾病", "待评价试验", "金标准", "研究问题"]
        },
        {
          "title": "方法",
          "required": true,
          "items": ["检索策略", "纳入标准", "数据提取", "质量评价QUADAS-2", "统计分析"]
        },
        {
          "title": "结果",
          "required": true,
          "items": ["敏感性", "特异性", "SROC曲线", "似然比", "诊断比值比"]
        }
      ],
      "quadas2_domains": ["病例选择", "待评价试验", "金标准", "流程与时机"]
    },
    {
      "id": "sr-prognostic",
